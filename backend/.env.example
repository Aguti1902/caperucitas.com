# Base de datos (Supabase)
DATABASE_URL="postgresql://postgres:PASSWORD@db.XXXX.supabase.co:5432/postgres"

# JWT (genera una clave larga y aleatoria)
JWT_SECRET="tu-clave-secreta-muy-larga-aqui"
JWT_ACCESS_SECRET="tu-clave-secreta-muy-larga-aqui"
JWT_REFRESH_SECRET="tu-clave-secreta-refresh-aqui"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# Servidor
PORT=4000
NODE_ENV="production"

# Frontend URL (tu dominio de Vercel o caperucitas.com)
FRONTEND_URL="https://caperucitas.com,https://www.caperucitas.com"

# Admin
ADMIN_PASSWORD="cambia-esta-contraseña"

# Cloudinary (para subida de fotos - opcional por ahora)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
